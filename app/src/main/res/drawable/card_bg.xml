<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#FFFFFF"/>

    <!-- Rounded corners -->
    <corners android:radius="16dp"/>

    <!-- Border (optional premium look) -->
    <stroke
        android:width="1dp"
        android:color="#E6E6E6"/>

    <!-- Padding effect inside shadow area -->
    <padding
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp"/>

</shape>