<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background"
    android:layout_width="match_parent"
    android:id="@+id/user_dashboard"
    android:fitsSystemWindows="false"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TOP HEADER -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="My Dashboard"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <ImageView
                android:src="@android:drawable/ic_menu_myplaces"
                android:layout_width="28dp"
                android:layout_height="28dp"
                app:tint="@color/text_primary" />
        </LinearLayout>

        <View
            android:layout_height="20dp"
            android:layout_width="match_parent"/>

        <!-- STATS CARDS -->
        <GridLayout
            android:columnCount="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- TOTAL POINTS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Total Points"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:id="@+id/tvTotalPoints"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TODAY EARNED -->
            <com.google.android.material.card.MaterialCardView
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Today Earned"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:id="@+id/tvTodayPoints"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- WITHDRAW STATUS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Withdraw"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:id="@+id/tvWithdraw"
                        android:text="Pending"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- HISTORY -->
            <com.google.android.material.card.MaterialCardView
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/card_bg"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="History"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="View"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- QUICK ACTIONS -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Quick Actions"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWithdraw"
            android:text="Request Withdraw"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/primary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:text="View Transaction History"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/primary"/>

        <!-- RECENT SECTION -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Recent Activity"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="20dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/card_bg"
            android:layout_width="match_parent"
            android:layout_height="120dp">

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:padding="16dp"
                android:text="No recent transactions"
                android:textColor="@color/text_secondary"/>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            app:itemIconTint="@color/primary"
            app:itemTextColor="@color/text_secondary"
            app:menu="@menu/bottom_menu"/>
    </LinearLayout>



</ScrollView>