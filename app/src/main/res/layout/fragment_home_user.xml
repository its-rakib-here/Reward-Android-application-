<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F6F8FB"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="18dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 🔝 HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:text="Dashboard"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_user"
                app:tint="#616161"/>
        </LinearLayout>

        <!-- 💰 WALLET CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:backgroundTint="#4CAF50"
            android:background="@drawable/bg_wallet_gradient"
                       >

            <LinearLayout
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Available Balance"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:id="@+id/tvMoney"
                    android:text="৳ 0.00"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:id="@+id/tvTotalPoints"
                    android:text="0 Points"
                    android:textColor="#E0E0E0"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 📊 STATS -->
        <GridLayout
            android:layout_marginTop="12dp"
            android:columnCount="2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- TODAY -->
            <com.google.android.material.card.MaterialCardView
                android:layout_margin="6dp"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Today Earned"
                        android:textColor="#757575"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:id="@+id/tvTodayPoints"
                        android:text="0"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#212121"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- WITHDRAW -->
            <com.google.android.material.card.MaterialCardView
                android:layout_margin="6dp"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:text="Withdraw Status"
                        android:textColor="#757575"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:id="@+id/tvWithdraw"
                        android:text="Pending"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- ⚡ ACTIONS -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Quick Actions"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginTop="18dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWithdraw"
            android:text="Withdraw Money"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            app:cornerRadius="14dp"
            android:backgroundTint="#4CAF50"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            android:text="Transaction History"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            app:cornerRadius="14dp"
            android:backgroundTint="#212121"/>

        <!-- 📜 RECENT -->
        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:text="Recent Activity"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginTop="18dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:padding="16dp"
                android:text="No recent transactions"
                android:textColor="#9E9E9E"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>