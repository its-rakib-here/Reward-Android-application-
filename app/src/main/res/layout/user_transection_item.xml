<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_margin="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E6E6E6"
    app:cardBackgroundColor="#FFFFFF"
    android:layout_height="wrap_content">

    <LinearLayout
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <TextView
            android:id="@+id/txnTitle"
            android:text="Transaction Title"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1E1E1E"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- POINTS -->
        <TextView
            android:id="@+id/txnPoints"
            android:text="+100 pts"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:textColor="#2E7D32"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- MONEY -->
        <TextView
            android:id="@+id/txnAmount"
            android:text="৳ 0.00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:textColor="#1565C0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- BOTTOM ROW -->
        <LinearLayout
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- DATE -->
            <TextView
                android:id="@+id/txnDate"
                android:text="2026-04-19"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <!-- STATUS CHIP -->
            <TextView
                android:id="@+id/txnStatus"
                android:text="PENDING"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/status_bg"
                android:textColor="@color/primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>